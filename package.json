{
  "name": "my-places-mcp",
  "version": "0.1.0",
  "description": "MCP server for Google Maps places",
  "type": "module",
  "bin": {
    "my-places-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "npm run test:jest && npm run test:native",
    "test:jest": "NODE_OPTIONS='--experimental-vm-modules' jest --runInBand",
    "test:native": "node --import tsx --test --test-concurrency=1 tests/native/*.test.ts",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "run:get-places": "tsc && node dist/bin/run-get-places.js",
    "prepare": "husky"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.1",
    "playwright": "^1.41.0"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/jsdom": "^27.0.0",
    "@types/node": "^20.11.0",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "ts-jest": "^29.4.6",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3"
  }
}
